{
  "name": "algocoach",
  "version": "1.8.2",
  "private": true,
  "description": "A bilingual, AI-assisted algorithm learning workspace.",
  "author": "AlgoCoach",
  "homepage": "https://algocoach.example",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=22.13.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/wuyu222dii/AI_Algorithm_Tutor"
  },
  "keywords": [
    "algocoach",
    "algorithm-learning",
    "coding-practice",
    "ai-tutor"
  ],
  "scripts": {
    "dev": "tsx scripts/with-env.ts --mode=development tsx scripts/start-with-db.ts dev --turbopack",
    "build": "next build",
    "build:fast": "NODE_OPTIONS='--max-old-space-size=4096' next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:ci": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "test:db:integration": "tsx scripts/test-postgres-integration.ts",
    "eval:coach": "tsx scripts/eval-coach.ts",
    "eval:coach:live:corpus": "tsx --tsconfig scripts/tsconfig.live-eval.json scripts/eval-coach-live.ts --validate-corpus",
    "eval:coach:live": "tsx scripts/with-env.ts --mode=production tsx --tsconfig scripts/tsconfig.live-eval.json scripts/eval-coach-live.ts",
    "budget:editor": "node scripts/check-editor-assets.mjs",
    "catalog:generate": "tsx scripts/generate-coach-catalog-migration.ts",
    "catalog:generate:hard": "tsx scripts/generate-coach-catalog-migration.ts --hard",
    "catalog:generate:exercism": "tsx scripts/generate-coach-exercism-seed.ts",
    "catalog:bootstrap": "tsx scripts/with-env.ts --mode=production tsx scripts/coach-catalog.ts bootstrap",
    "catalog:discover": "tsx scripts/with-env.ts --mode=production tsx scripts/coach-catalog.ts discover",
    "catalog:monitor": "tsx scripts/with-env.ts --mode=production tsx scripts/coach-catalog.ts monitor",
    "catalog:sync:dry-run": "tsx scripts/with-env.ts --mode=production tsx scripts/coach-catalog.ts dry-run",
    "catalog:sync": "tsx scripts/with-env.ts --mode=production tsx scripts/coach-catalog.ts sync",
    "catalog:validate": "tsx scripts/with-env.ts --mode=production tsx scripts/coach-catalog.ts validate",
    "catalog:approve": "tsx scripts/with-env.ts --mode=production tsx scripts/coach-catalog.ts approve",
    "catalog:publish": "tsx scripts/with-env.ts --mode=production tsx scripts/coach-catalog.ts publish",
    "catalog:rollback": "tsx scripts/with-env.ts --mode=production tsx scripts/coach-catalog.ts rollback",
    "assets:coach": "tsx scripts/capture-product-assets.ts",
    "check": "pnpm format:check && pnpm typecheck && pnpm lint:ci && pnpm test && pnpm eval:coach && pnpm eval:coach:live:corpus && pnpm budget:editor && pnpm build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "tsx scripts/with-env.ts --mode=development npx drizzle-kit generate --config=src/core/db/config.ts",
    "db:migrate": "tsx scripts/with-env.ts --mode=development tsx scripts/migrate-database.ts",
    "db:migrate:release": "tsx scripts/with-env.ts --mode=production tsx scripts/migrate-database.ts --require-application-role",
    "db:migrate:prod": "pnpm db:migrate:release",
    "db:push": "tsx scripts/with-env.ts --mode=development npx drizzle-kit push --config=src/core/db/config.ts",
    "db:studio": "tsx scripts/with-env.ts --mode=development npx drizzle-kit studio --config=src/core/db/config.ts",
    "auth:generate": "tsx scripts/with-env.ts npx @better-auth/cli generate --config=src/core/auth/index.ts",
    "rbac:init": "tsx scripts/with-env.ts npx tsx scripts/init-rbac.ts",
    "rbac:assign": "tsx scripts/with-env.ts npx tsx scripts/assign-role.ts",
    "postinstall": "fumadocs-mdx && node scripts/copy-pyodide-assets.mjs",
    "cf:preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "cf:deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf:upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf:typegen": "wrangler types --env-interface CloudflareEnv src/shared/types/cloudflare.d.ts"
  },
  "dependencies": {
    "@ai-sdk/react": "^2.0.89",
    "@ai-sdk/replicate": "^1.0.8",
    "@better-fetch/fetch": "^1.1.18",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
