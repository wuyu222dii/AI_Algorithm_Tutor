    "recharts": "2.15.4",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "replicate": "^1.3.1",
    "resend": "^6.0.3",
    "rough-notation": "^0.5.1",
    "shiki": "^3.20.0",
    "simple-flakeid": "^0.0.5",
    "sonner": "^2.0.7",
