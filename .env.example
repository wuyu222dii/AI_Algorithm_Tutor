# app
NEXT_PUBLIC_APP_URL = "http://localhost:3000"
NEXT_PUBLIC_APP_NAME = "AlgoCoach"
NEXT_PUBLIC_APP_DESCRIPTION = "AI algorithm coach for guided practice, immediate feedback, assessment, and review."
NEXT_PUBLIC_APP_LOGO = "/logo.png"
NEXT_PUBLIC_APP_FAVICON = "/favicon.ico"
NEXT_PUBLIC_APP_PREVIEW_IMAGE = "/preview.png"
NEXT_PUBLIC_DEFAULT_LOCALE = "zh"
NEXT_PUBLIC_LOCALE_DETECT_ENABLED = "false"

# theme
NEXT_PUBLIC_THEME = "default"

# appearance
NEXT_PUBLIC_APPEARANCE = "system"

# database
DATABASE_PROVIDER = "postgresql"
# Runtime application role: DML only, without schema creation permissions.
DATABASE_URL = ""
# Existing role name granted DML and migration-history read access by release.
DATABASE_APPLICATION_ROLE = "algocoach_app"
# Release/migration role: DDL permissions; inject only into the migration job.
MIGRATION_DATABASE_URL = ""
DB_SCHEMA_FILE = "./src/config/db/schema.postgres.ts"
DB_SCHEMA = "algocoach"
DB_MIGRATIONS_OUT = "./src/config/db/migrations"
DB_MIGRATIONS_SCHEMA = "drizzle"
DB_MIGRATIONS_TABLE = "__drizzle_migrations"
# Development startup only. Opt in after configuring MIGRATION_DATABASE_URL.
# DATABASE_URL is never used as a migration fallback.
DB_AUTO_MIGRATE = "false"
DB_MIGRATION_LOCK_TIMEOUT_MS = "30000"
DB_MIGRATION_STATEMENT_TIMEOUT_MS = "60000"
DB_SINGLETON_ENABLED = "true"
DB_MAX_CONNECTIONS = "1"
HEALTH_DATABASE_TIMEOUT_MS = "5000"
NEXT_PUBLIC_COACH_CLOUD_SYNC_ENABLED = "true"
# Published catalog reads come from PostgreSQL when enabled. Keep this true in
# production after the versioned catalog migration has been released.
DB_CATALOG_ENABLED = "true"
# Scheduled upstream fetches only create review candidates; they never publish.
CATALOG_SYNC_ENABLED = "false"
# Server-only reviewer/publisher connection. The login should inherit both
# NOLOGIN capability roles and is never exposed to browser code or sync jobs.
CATALOG_ADMIN_DATABASE_URL = ""
# One-time baseline command only. Never leave enabled in an app deployment.
CATALOG_BOOTSTRAP_ENABLED = "false"
# Git Tree discovery creates non-publishable review artifacts for exercises that
# are not yet represented by the curated adapter list.
CATALOG_DISCOVERY_ENABLED = "false"
CATALOG_DISCOVERY_MAX_EXERCISES = "20"
# Alert when a single discovery run changes more candidates or tree entries.
CATALOG_ANOMALY_DELTA_THRESHOLD = "25"
# Allows the discovery CLI to persist non-publishable raw drafts in quarantine.
CATALOG_DISCOVERY_INGEST_ENABLED = "false"
# Optional OpenRouter enrichment. Model must be on the coach whitelist; it may
# propose metadata and a signature, while templates are generated locally and
# solutions, hints and tests remain excluded.
CATALOG_AI_DRAFT_ENABLED = "false"
CATALOG_AI_MODEL = "google/gemini-2.5-flash"
# Enables the browser TypeScript runner after the catalog and state migrations.
TYPESCRIPT_ENABLED = "true"
# Optional GitHub token for higher API rate limits in the scheduled sync job.
EXERCISM_GITHUB_TOKEN = ""

# auth
# Keep AUTH_URL aligned with the public app origin in each environment.
AUTH_URL = "http://localhost:3000"
# openssl rand -base64 32
AUTH_SECRET = ""
# Optional dedicated key; defaults to AUTH_SECRET.
ASSESSMENT_SIGNING_SECRET = ""
EMAIL_AUTH_ENABLED = "true"
EMAIL_VERIFICATION_ENABLED = "false"

# Auth request throttling
AUTH_GET_SESSION_RATE_WINDOW_MS = "60000"
AUTH_GET_SESSION_RATE_MAX = "120"
NEXT_PUBLIC_AUTH_GET_SESSION_MIN_INTERVAL_MS = "2000"
AUTH_SOCIAL_SIGN_IN_RATE_WINDOW_MS = "60000"
AUTH_SOCIAL_SIGN_IN_RATE_MAX = "20"
AUTH_SIGN_IN_RATE_WINDOW_MS = "60000"
AUTH_SIGN_IN_RATE_MAX = "10"
AUTH_SIGN_UP_RATE_WINDOW_MS = "600000"
AUTH_SIGN_UP_RATE_MAX = "3"
AUTH_PASSWORD_RESET_RATE_WINDOW_MS = "600000"
AUTH_PASSWORD_RESET_RATE_MAX = "3"
AUTH_VERIFICATION_EMAIL_RATE_WINDOW_MS = "600000"
AUTH_VERIFICATION_EMAIL_RATE_MAX = "3"

# Redis-compatible HTTP REST backend. Optional for local development; required
# in production so auth and coach limits remain consistent across instances.
REDIS_URL = ""
REDIS_TOKEN = ""
HEALTH_REDIS_TIMEOUT_MS = "5000"
# Only list client-IP headers that your edge proxy overwrites. Required in production.
TRUSTED_PROXY_HEADERS = "x-forwarded-for"

# Email delivery. Both values are required for verification and password reset.
RESEND_API_KEY = ""
RESEND_SENDER_EMAIL = "AlgoCoach <no-reply@your-domain.example>"

# Optional social authentication
GOOGLE_AUTH_ENABLED = "false"
GOOGLE_ONE_TAP_ENABLED = "false"
GOOGLE_CLIENT_ID = ""
GOOGLE_CLIENT_SECRET = ""
GITHUB_AUTH_ENABLED = "false"
GITHUB_CLIENT_ID = ""
GITHUB_CLIENT_SECRET = ""

# AI coach (required for AI feedback; the API returns 503 without a key)
OPENROUTER_API_KEY = ""
OPENROUTER_BASE_URL = ""
# Must exactly match an ID returned by the configured provider's /models API.
ALGO_COACH_MODEL = ""
# Optional global failover model. Per-action overrides follow the same whitelist,
# for example ALGO_COACH_HINT_MODEL and ALGO_COACH_HINT_FALLBACK_MODEL.
ALGO_COACH_FALLBACK_MODEL = ""
# Optional action routing. Blank values inherit the two global model settings.
ALGO_COACH_PARSE_MODEL = ""
ALGO_COACH_DIAGNOSE_MODEL = ""
ALGO_COACH_HINT_MODEL = ""
ALGO_COACH_COUNTEREXAMPLE_MODEL = ""
ALGO_COACH_REVIEW_CARD_MODEL = ""
ALGO_COACH_CHAT_MODEL = ""
# Every action also accepts a matching *_FALLBACK_MODEL override.
COACH_PROVIDER_TIMEOUT_MS = "10000"
COACH_CIRCUIT_BREAKER_FAILURES = "3"
COACH_CIRCUIT_BREAKER_DURATION_MS = "60000"
# Optional global pricing fallback. Model-specific values take precedence.
COACH_INPUT_COST_PER_MILLION_USD = ""
COACH_OUTPUT_COST_PER_MILLION_USD = ""
COACH_GEMINI_2_5_FLASH_INPUT_COST_PER_MILLION_USD = ""
COACH_GEMINI_2_5_FLASH_OUTPUT_COST_PER_MILLION_USD = ""
COACH_GPT_5_5_INPUT_COST_PER_MILLION_USD = ""
COACH_GPT_5_5_OUTPUT_COST_PER_MILLION_USD = ""
COACH_CLAUDE_4_5_SONNET_INPUT_COST_PER_MILLION_USD = ""
COACH_CLAUDE_4_5_SONNET_OUTPUT_COST_PER_MILLION_USD = ""
# Deterministic curated-problem fallback for local development and tests only.
# Production readiness always requires a live OpenRouter key.
COACH_DEMO_FALLBACK_ENABLED = "false"
COACH_RATE_LIMIT_PER_MINUTE = "20"
COACH_RATE_LIMIT_PER_10_SECONDS = "5"
COACH_AUTHENTICATED_DAILY_REQUESTS = "200"
COACH_GUEST_DAILY_REQUESTS = "40"
COACH_MAX_CONCURRENCY = "2"
COACH_IP_MAX_CONCURRENCY = "6"
COACH_AUTHENTICATED_DAILY_TOKENS = "200000"
COACH_GUEST_DAILY_TOKENS = "40000"
COACH_IP_DAILY_TOKENS = "400000"
COACH_AUTHENTICATED_DAILY_COST_USD = "0.05"
COACH_GUEST_DAILY_COST_USD = "0.05"
COACH_IP_DAILY_COST_USD = "0.20"
COACH_ARTIFACT_RESERVED_TOKENS = "1800"
COACH_CHAT_RESERVED_TOKENS = "1000"
COACH_ARTIFACT_RESERVED_COST_USD = "0.010"
COACH_CHAT_RESERVED_COST_USD = "0.008"
COACH_GENERATION_LEASE_MS = ""

# Optional server-side telemetry exporters.
SENTRY_DSN = ""
OTEL_EXPORTER_OTLP_LOGS_ENDPOINT = ""
OTEL_EXPORTER_OTLP_HEADERS = ""

# Legacy ShipAny endpoints stay disabled in the AlgoCoach demo.
FILE_PROXY_ALLOWED_HOSTS = ""
