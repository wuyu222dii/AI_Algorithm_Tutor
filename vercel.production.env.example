# Replace every REPLACE_* value before importing this file into Vercel.
# Apply these values to Production. Configure Preview separately with its own URL and credentials.

# Public application
NEXT_PUBLIC_APP_URL=https://www.algocoach.shop/
NEXT_PUBLIC_APP_NAME=AlgoCoach
NEXT_PUBLIC_APP_DESCRIPTION="AI algorithm coach for guided practice, immediate feedback, assessment, and review."
NEXT_PUBLIC_APP_LOGO=/logo.png
NEXT_PUBLIC_APP_FAVICON=/favicon.ico
NEXT_PUBLIC_APP_PREVIEW_IMAGE=/preview.png
NEXT_PUBLIC_SUPPORT_EMAIL=REPLACE_WITH_REAL_SUPPORT_EMAIL
NEXT_PUBLIC_DEFAULT_LOCALE=zh
NEXT_PUBLIC_LOCALE_DETECT_ENABLED=false
NEXT_PUBLIC_THEME=default
NEXT_PUBLIC_APPEARANCE=system
NEXT_PUBLIC_COACH_CLOUD_SYNC_ENABLED=true
NEXT_PUBLIC_DURABLE_GUEST_CLAIM_ENABLED=false

# Restricted PostgreSQL runtime connection. Use the Supabase Session Pooler when required by Vercel networking.
DATABASE_PROVIDER=postgresql
DATABASE_URL=REPLACE_WITH_RESTRICTED_SUPABASE_RUNTIME_URL
DATABASE_APPLICATION_ROLE=algocoach_app
DB_SCHEMA_FILE=./src/config/db/schema.postgres.ts
DB_SCHEMA=algocoach
DB_MIGRATIONS_OUT=./src/config/db/migrations
DB_MIGRATIONS_SCHEMA=drizzle
DB_MIGRATIONS_TABLE=__drizzle_migrations
DB_AUTO_MIGRATE=false
DB_SINGLETON_ENABLED=true
DB_MAX_CONNECTIONS=1
HEALTH_DATABASE_TIMEOUT_MS=5000
DB_CATALOG_ENABLED=true
CATALOG_MIN_PUBLISHED_PROBLEMS=73
SUMMARY_CATALOG_ENABLED=false
TYPESCRIPT_ENABLED=true

# Catalog admin remains disabled until a separate reviewer/publisher login is configured.
CATALOG_SYNC_ENABLED=false
CATALOG_STRUCTURED_REVIEW_MODE=shadow
CATALOG_AI_DRAFT_ENABLED=false
CATALOG_AI_MODEL=gpt-5.5

# Authentication. AUTH_URL must exactly match NEXT_PUBLIC_APP_URL.
AUTH_URL=https://REPLACE_WITH_PRODUCTION_ORIGIN
AUTH_SECRET=REPLACE_ME
EMAIL_AUTH_ENABLED=false
EMAIL_VERIFICATION_ENABLED=false
GOOGLE_AUTH_ENABLED=true
GOOGLE_ONE_TAP_ENABLED=false
GOOGLE_CLIENT_ID=REPLACE_ME
GOOGLE_CLIENT_SECRET=REPLACE_ME
GITHUB_AUTH_ENABLED=false
TRUSTED_PROXY_HEADERS=x-forwarded-for

# Authentication throttling
AUTH_GET_SESSION_RATE_WINDOW_MS=60000
AUTH_GET_SESSION_RATE_MAX=120
NEXT_PUBLIC_AUTH_GET_SESSION_MIN_INTERVAL_MS=2000
AUTH_SOCIAL_SIGN_IN_RATE_WINDOW_MS=60000
AUTH_SOCIAL_SIGN_IN_RATE_MAX=20
AUTH_SIGN_IN_RATE_WINDOW_MS=60000
AUTH_SIGN_IN_RATE_MAX=10
AUTH_SIGN_UP_RATE_WINDOW_MS=600000
AUTH_SIGN_UP_RATE_MAX=3
AUTH_PASSWORD_RESET_RATE_WINDOW_MS=600000
AUTH_PASSWORD_RESET_RATE_MAX=3
AUTH_VERIFICATION_EMAIL_RATE_WINDOW_MS=600000
AUTH_VERIFICATION_EMAIL_RATE_MAX=3

# HTTPS Redis HTTP REST endpoint, not redis:// or rediss://.
REDIS_URL=REPLACE_WITH_HTTPS_REDIS_REST_URL
REDIS_TOKEN=REPLACE_ME
REDIS_ALLOW_INSECURE_LOCAL=false
HEALTH_REDIS_TIMEOUT_MS=5000

# codeapix OpenAI-compatible relay
AI_RELAY_API_KEY=REPLACE_ME
AI_RELAY_BASE_URL=https://codeapix.top/v1
AI_RELAY_PRIMARY_MODEL=gpt-5.5
AI_RELAY_FALLBACK_MODEL=gpt-5.4-mini
AI_RELAY_STRUCTURED_OUTPUT_MODE=json-schema
AI_RELAY_CANARY_TOKEN=REPLACE_ME
AI_RELAY_CANARY_TIMEOUT_MS=8000
AI_RELAY_PRICING_JSON={"gpt-5.5":{"inputPerMillionUsd":22.5,"outputPerMillionUsd":180},"gpt-5.4-mini":{"inputPerMillionUsd":3.375,"outputPerMillionUsd":20.25}}

# Per-action routing. Every value must be one of the two preflighted relay models above.
ALGO_COACH_PARSE_MODEL=gpt-5.4-mini
ALGO_COACH_PARSE_FALLBACK_MODEL=gpt-5.5
ALGO_COACH_DIAGNOSE_MODEL=gpt-5.5
ALGO_COACH_DIAGNOSE_FALLBACK_MODEL=gpt-5.4-mini
ALGO_COACH_HINT_MODEL=gpt-5.4-mini
ALGO_COACH_HINT_FALLBACK_MODEL=gpt-5.5
ALGO_COACH_COUNTEREXAMPLE_MODEL=gpt-5.5
ALGO_COACH_COUNTEREXAMPLE_FALLBACK_MODEL=gpt-5.4-mini
ALGO_COACH_REVIEW_CARD_MODEL=gpt-5.4-mini
ALGO_COACH_REVIEW_CARD_FALLBACK_MODEL=gpt-5.5
ALGO_COACH_REVIEW_GRADE_MODEL=gpt-5.4-mini
ALGO_COACH_REVIEW_GRADE_FALLBACK_MODEL=gpt-5.5
ALGO_COACH_CHAT_MODEL=gpt-5.4-mini
ALGO_COACH_CHAT_FALLBACK_MODEL=gpt-5.5

# AI reliability, rate limits, and budget controls
COACH_PROVIDER_TIMEOUT_MS=10000
COACH_CIRCUIT_BREAKER_FAILURES=3
COACH_CIRCUIT_BREAKER_DURATION_MS=60000
COACH_DEMO_FALLBACK_ENABLED=false
COACH_RATE_LIMIT_PER_MINUTE=20
COACH_RATE_LIMIT_PER_10_SECONDS=5
COACH_AUTHENTICATED_DAILY_REQUESTS=200
COACH_GUEST_DAILY_REQUESTS=40
COACH_MAX_CONCURRENCY=2
COACH_IP_MAX_CONCURRENCY=6
COACH_AUTHENTICATED_DAILY_TOKENS=200000
COACH_GUEST_DAILY_TOKENS=40000
COACH_IP_DAILY_TOKENS=400000
COACH_AUTHENTICATED_DAILY_COST_USD=1.00
COACH_GUEST_DAILY_COST_USD=1.00
COACH_IP_DAILY_COST_USD=5.00
COACH_ARTIFACT_RESERVED_TOKENS=1800
COACH_CHAT_RESERVED_TOKENS=1000
COACH_ARTIFACT_RESERVED_COST_USD=0.010
COACH_CHAT_RESERVED_COST_USD=0.008

# P0 rollout flags. Keep the durable pair equal.
DURABLE_GUEST_CLAIM_ENABLED=false
ANONYMOUS_METRICS_ENABLED=false

# Sentry runtime and source-map upload
SENTRY_DSN=REPLACE_ME
NEXT_PUBLIC_SENTRY_DSN=REPLACE_ME
NEXT_PUBLIC_WEB_VITALS_SAMPLE_RATE=0.10
SENTRY_ORG=REPLACE_ME
SENTRY_PROJECT=REPLACE_ME
SENTRY_AUTH_TOKEN=REPLACE_ME

# Optional runtime values. Uncomment only after configuring the corresponding service.
# ANONYMOUS_METRICS_HMAC_SECRET=REPLACE_WITH_RANDOM_SECRET_AT_LEAST_32_CHARACTERS
# ASSESSMENT_SIGNING_SECRET=REPLACE_WITH_RANDOM_SECRET_AT_LEAST_32_CHARACTERS
# CATALOG_ADMIN_DATABASE_URL=REPLACE_WITH_CATALOG_REVIEWER_PUBLISHER_URL
# RESEND_API_KEY=REPLACE_WITH_RESEND_KEY
# RESEND_SENDER_EMAIL=AlgoCoach <no-reply@your-domain.example>
# OTEL_EXPORTER_OTLP_LOGS_ENDPOINT=https://REPLACE_WITH_OTLP_ENDPOINT
# OTEL_EXPORTER_OTLP_HEADERS=REPLACE_WITH_OTLP_AUTHORIZATION_VALUE
# NEXT_PUBLIC_IMAGE_HOSTS=cdn.your-domain.example
# FILE_PROXY_ALLOWED_HOSTS=
